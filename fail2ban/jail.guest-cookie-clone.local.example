# Add this snippet to /etc/fail2ban/jail.local
# Dedicated jail for guest visitor-cookie strict behavior:
# - guest_cookie_clone_multi_ip
# - guest_cookie_ajax_fail

[phpbb-guest-cookie-clone]
enabled = true
port = http,https
filter = phpbb-guest-cookie-clone
backend = auto
logpath = /var/log/security_audit.log
maxretry = 1
findtime = 21600
bantime = 43200
bantime.increment = true
bantime.factor = 2
bantime.maxtime = 1209600
action = nftables-multiport[name=phpbb-guest-cookie-clone, port="http,https", protocol=tcp]
